# ─── InterviewAI — Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Anthropic (Claude API) ──────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Used by: Supabase Edge Functions (never expose in frontend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Stripe Price IDs (create these in Stripe Dashboard) ─────────────────────
VITE_STRIPE_STARTER_PRICE_ID=price_starter_monthly
VITE_STRIPE_PRO_PRICE_ID=price_pro_monthly
